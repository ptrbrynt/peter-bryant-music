---js 
{ now: new Date() }
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{{ title }} | Peter Bryant</title>
        {# <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300..700;1,300..700&family=Work+Sans:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet"> #}

        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.colors.min.css">

        <link rel="stylesheet" href="/prism.css">
        <script src="/prism.js"></script>

        <link rel="alternate" type="application/rss+xml" href="https://peterbryantmusic.com/feed.xml" title="Peter Bryant">

        <link rel="human-json" href="/human.json">

        <script>
            // Configure normalize-whitespace before Prism runs
            Prism
                .plugins
                .NormalizeWhitespace
                .setDefaults({
                    'remove-trailing': true, 'remove-indent': true, 'left-trim': true, 'right-trim': true, 'tabs-to-spaces': 2 // Dart convention — tightens indentation visually
                });
        </script>
        <link rel="stylesheet" href="/bundle.css">
    </head>
    <body>
        <header>
            <nav class="container">
                <ul>
                    <li>
                        <a {% if page.url == '/' %} aria-current="page" {% endif %} class="contrast" href="/">
                            <strong>Peter Bryant</strong>
                        </a>
                    </li>
                </ul>
                <ul>
                    {%- for pg in collections.page -%}
                        <li>
                            <a {% if page.url == pg.url %} aria-current="page" {% endif %} href={{ pg.url }}>{{ pg.data.title }}</a>
                        </li>
                    {%- endfor -%}
                </ul>
            </nav>
            <hr/>
        </header>

        <main class="container">
            {{ content | safe }}
        </main>

        <hr/>

        <footer class="site-footer">
            <div class="container">

                <ul class="footer-links">
                    {%- for pg in collections['footer-page'] -%}
                        <li class="footer-link">
                            <a {% if page.url == pg.url %} aria-current="page" {% endif %} href={{ pg.url }}>
                                <small>{{ pg.data.title }}</small>
                            </a>
                        </li>
                    {%- endfor -%}
                    <li class="footer-link">
                        <a href="https://buttondown.com/peterbryantmusic" target="_blank">
                            <small>Newsletter</small>
                        </a>
                </ul>

                <p>
                    <small>
                            Copyright © Peter Bryant {{ now | date("yyyy") }}
                    </small>
                </p>

            </div>
        </div>
    </footer>
</body>
</html>